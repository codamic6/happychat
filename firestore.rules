
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // --- REUSABLE SOURCE OF TRUTH ---
    // Verifies participation by checking the parent conversation document.
    function isConversationParticipant(conversationId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
      
      match /contacts/{contactId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow write: if isSignedIn() && (request.auth.uid == userId || request.auth.uid == contactId);
      }
    }

    // --- Conversations ---
    match /conversations/{conversationId} {
      
      allow read: if isConversationParticipant(conversationId);
      
      // Create is handled via request.resource since doc doesn't exist yet
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participantIds);
      
      allow update: if isConversationParticipant(conversationId);

      match /messages/{messageId} {
        // Source of truth is always the parent conversation
        allow read, write: if isConversationParticipant(conversationId);
      }
    }

    // --- Statuses ---
    match /statuses/{statusId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }
  }
}
