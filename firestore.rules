
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
      
      match /contacts/{contactId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow write: if isSignedIn() && (request.auth.uid == userId || request.auth.uid == contactId);
      }
    }

    // --- Conversations ---
    match /conversations/{conversationId} {
      // Helper to check if the current user is a participant of an existing conversation
      function isParticipant() {
        let path = /databases/$(database)/documents/conversations/$(conversationId);
        return isSignedIn() && exists(path) && (request.auth.uid in get(path).data.participantIds);
      }
      
      // Helper for creating a new conversation
      function isNewParticipant() {
        return isSignedIn() && (request.auth.uid in request.resource.data.participantIds);
      }

      allow read: if isParticipant();
      allow create: if isNewParticipant();
      allow update: if isParticipant();

      match /messages/{messageId} {
        // Users can read and write messages if they are participants of the parent conversation
        allow read, write: if isParticipant();
      }
    }

    // --- Statuses ---
    match /statuses/{statusId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }
  }
}
