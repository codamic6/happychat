
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Users ---
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
      
      match /contacts/{contactId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == contactId);
      }
    }

    // --- Conversations ---
    match /conversations/{conversationId} {
      // Helper to check if the current user is a participant
      function isParticipant() {
        return request.auth != null && (
          (resource != null && request.auth.uid in resource.data.participantIds) ||
          (request.resource != null && request.auth.uid in request.resource.data.participantIds)
        );
      }

      allow read: if isParticipant();
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;
      allow update: if isParticipant();

      match /messages/{messageId} {
        // User can read/write if they are a participant of the conversation
        // We check both the message document's cached IDs and the parent conversation's authoritative list
        function canAccessMessage() {
          let parentConv = get(/databases/$(database)/documents/conversations/$(conversationId));
          return request.auth != null && (
            (parentConv != null && request.auth.uid in parentConv.data.participantIds) ||
            (resource != null && request.auth.uid in resource.data.get('conversationParticipantIds', [])) ||
            (request.resource != null && request.auth.uid in request.resource.data.get('conversationParticipantIds', []))
          );
        }

        allow read, write: if canAccessMessage();
      }
    }

    // --- Statuses ---
    match /statuses/{statusId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
