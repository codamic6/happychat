
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Users ---
    match /users/{userId} {
      allow read, write: if request.auth != null;
      
      match /contacts/{contactId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // --- Conversations ---
    match /conversations/{conversationId} {
      // Allow reading if the user is a participant
      allow read: if request.auth != null && request.auth.uid in resource.data.participantIds;
      
      // Allow creation if the user is a participant in the new data
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;
      
      // Allow updates if the user is (or will be) a participant
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.participantIds || 
        request.auth.uid in request.resource.data.participantIds
      );

      // --- Messages ---
      match /messages/{messageId} {
        // Allow read/write if the user is a participant in this conversation
        allow read: if request.auth != null && request.auth.uid in resource.data.conversationParticipantIds;
        allow create: if request.auth != null && request.auth.uid in request.resource.data.conversationParticipantIds;
      }
    }
  }
}
