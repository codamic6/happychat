
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // --- Users ---
    match /users/{userId} {
      allow read, write: if isSignedIn();
      
      match /contacts/{contactId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // --- Conversations ---
    match /conversations/{conversationId} {
      // Allow read/write if user is in participantIds array
      allow read, write: if isSignedIn() && (
        request.auth.uid in resource.data.participantIds ||
        request.auth.uid in request.resource.data.participantIds
      );

      // --- Messages ---
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && (
          request.auth.uid in resource.data.conversationParticipantIds ||
          request.auth.uid in request.resource.data.conversationParticipantIds
        );
      }
    }
  }
}
