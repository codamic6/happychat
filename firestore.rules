
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
      
      match /contacts/{contactId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow write: if isSignedIn() && (request.auth.uid == userId || request.auth.uid == contactId);
      }
    }

    // --- Conversations ---
    match /conversations/{conversationId} {
      
      // Check if the user is a participant of the conversation
      function isParticipant() {
        return isSignedIn() && (request.auth.uid in resource.data.participantIds);
      }
      
      // Check if the user is a participant in a new conversation request
      function isNewParticipant() {
        return isSignedIn() && (request.auth.uid in request.resource.data.participantIds);
      }

      // Check participation in the parent conversation for subcollection access
      function isParentParticipant() {
        let conv = get(/databases/$(database)/documents/conversations/$(conversationId));
        return isSignedIn() && (request.auth.uid in conv.data.participantIds);
      }

      allow read: if isParticipant();
      allow create: if isNewParticipant();
      allow update: if isParticipant();

      match /messages/{messageId} {
        // Users can read and write messages if they are participants of the parent conversation
        allow read, write: if isParentParticipant();
      }
    }

    // --- Statuses ---
    match /statuses/{statusId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }
  }
}
