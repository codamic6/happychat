
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile and account information within the HappyChat application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "username": {
          "type": "string",
          "description": "A unique, user-chosen handle for identification."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "fullName": {
          "type": "string",
          "description": "The user's full name."
        },
        "phoneNumber": {
          "type": "string",
          "description": "The user's contact phone number."
        },
        "profileImageUrl": {
          "type": "string",
          "description": "URL to the user's profile picture.",
          "format": "uri"
        },
        "megaId": {
          "type": "string",
          "description": "MEGA File ID for the avatar."
        },
        "megaKey": {
          "type": "string",
          "description": "MEGA decryption key fragment for the avatar."
        },
        "about": {
          "type": "string",
          "description": "A short bio for the user."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "username",
        "email",
        "fullName",
        "createdAt",
        "updatedAt"
      ]
    },
    "Contact": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Contact",
      "type": "object",
      "description": "Represents a saved contact relationship.",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the contact."
        },
        "addedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "userId",
        "addedAt"
      ]
    },
    "Conversation": {
      "title": "Conversation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participantIds": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "unreadCount": { "type": "object" }
      }
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "conversationParticipantIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "StatusUpdate": {
      "title": "StatusUpdate",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image"] },
        "megaId": { "type": "string" },
        "megaKey": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com",
      "github.com",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Stores individual user profiles."
        }
      },
      {
        "path": "/users/{userId}/contacts/{contactId}",
        "definition": {
          "entityName": "Contact",
          "schema": { "$ref": "#/backend/entities/Contact" },
          "description": "Stores a user's personal contact list."
        }
      },
      {
        "path": "/conversations/{conversationId}",
        "definition": {
          "entityName": "Conversation",
          "schema": { "$ref": "#/backend/entities/Conversation" },
          "description": "Stores shared chat sessions."
        }
      },
      {
        "path": "/conversations/{conversationId}/messages/{messageId}",
        "definition": {
          "entityName": "Message",
          "schema": { "$ref": "#/backend/entities/Message" },
          "description": "Stores individual messages within a conversation."
        }
      },
      {
        "path": "/statuses/{statusId}",
        "definition": {
          "entityName": "StatusUpdate",
          "schema": { "$ref": "#/backend/entities/StatusUpdate" },
          "description": "Stores temporary user status updates."
        }
      }
    ]
  }
}
